# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare source code files to use LF
*.go text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf

# Workflow files should use LF
.github/workflows/*.yml text eol=lf
.github/workflows/*.yaml text eol=lf

# Shell scripts should use LF
*.sh text eol=lf

# Windows batch files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Markdown files can use LF
*.md text eol=lf
